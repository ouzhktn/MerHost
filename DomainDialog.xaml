<Window x:Class="MerHost.DomainDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Domain Oluştur" Height="350" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1E1E1E">
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Domain Name -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Domain Adı" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="DomainTextBox" Text=""/>
                <TextBlock Grid.Column="1" Text=".test" Foreground="#AAA" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="14" FontWeight="Bold"/>
            </Grid>
            <TextBlock Text="Örn: projem, blog, api" Foreground="#888" FontSize="12" Margin="0,5,0,0"/>
        </StackPanel>
        
        <!-- Project Folder -->
        <StackPanel Grid.Row="1" Margin="0,25,0,0">
            <TextBlock Text="Proje Klasörü" Margin="0,0,0,8"/>
            <ComboBox x:Name="FolderComboBox" IsEditable="False" Height="35"/>
            <TextBlock Text="www klasöründeki proje klasörünü seçin" Foreground="#888" FontSize="12" Margin="0,5,0,0"/>
        </StackPanel>
        
        <!-- Info -->
        <Border Grid.Row="2" Background="#1A237E" Padding="15" Margin="0,25,0,0" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="Otomatik yapılacaklar:" Foreground="#9FA8DA" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="• hosts dosyasına domain eklenecek" Foreground="#C5CAE9" FontSize="12" Margin="15,8,0,0"/>
                <TextBlock Text="• SSL sertifikası oluşturulacak" Foreground="#C5CAE9" FontSize="12" Margin="15,4,0,0"/>
                <TextBlock Text="• Sertifika güvenilir olarak yüklenecek" Foreground="#C5CAE9" FontSize="12" Margin="15,4,0,0"/>
                <TextBlock Text="• Nginx yapılandırması güncellenecek" Foreground="#C5CAE9" FontSize="12" Margin="15,4,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="İptal" Click="Cancel_Click" Padding="25,10" Background="#424242" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14"/>
            <Button Content="Oluştur" Click="Create_Click" Padding="25,10" Margin="15,0,0,0" Background="#2E7D32" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
