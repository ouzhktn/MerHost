<Window x:Class="MerHost.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ayarlar" Height="500" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1E1E1E">
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="MerHost Ayarlar" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" Foreground="#4FC3F7"/>
        
        <!-- HTTP Port -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="HTTP Port" Margin="0,0,0,8"/>
            <TextBox x:Name="HttpPortTextBox" Text="80" Width="100" HorizontalAlignment="Left"/>
        </StackPanel>
        
        <!-- HTTPS Port -->
        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="HTTPS Port" Margin="0,0,0,8"/>
            <TextBox x:Name="HttpsPortTextBox" Text="443" Width="100" HorizontalAlignment="Left"/>
        </StackPanel>
        
        <!-- Auto-start -->
        <StackPanel Grid.Row="3" Margin="0,20,0,0">
            <TextBlock Text="Başlangıç Ayarları" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <CheckBox x:Name="AutoStartCheckBox" Content="Windows ile birlikte başlat" Margin="0,5,0,0"/>
            <CheckBox x:Name="StartMinimizedCheckBox" Content="Simge durumunda başlat" Margin="0,10,0,0"/>
            <CheckBox x:Name="AutoStartServersCheckBox" Content="Sunucuları otomatik başlat" Margin="0,10,0,0"/>
        </StackPanel>
        
        <!-- Version Info -->
        <Border Grid.Row="4" Background="#263238" Padding="15" Margin="0,20,0,0" CornerRadius="6">
            <StackPanel>
                <TextBlock Text="Sürüm Bilgileri" Foreground="#B0BEC5" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Nginx:" Foreground="#90A4AE" Width="120"/>
                    <TextBlock x:Name="NginxVersionText" Foreground="#ECEFF1"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="PHP:" Foreground="#90A4AE" Width="120"/>
                    <TextBlock x:Name="PhpVersionText" Foreground="#ECEFF1"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="MariaDB:" Foreground="#90A4AE" Width="120"/>
                    <TextBlock x:Name="MysqlVersionText" Foreground="#ECEFF1"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="phpMyAdmin:" Foreground="#90A4AE" Width="120"/>
                    <TextBlock x:Name="PhpMyAdminVersionText" Foreground="#ECEFF1"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="İptal" Click="Cancel_Click" Padding="25,10" Background="#424242" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14"/>
            <Button Content="Kaydet" Click="Save_Click" Padding="25,10" Margin="15,0,0,0" Background="#1976D2" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
