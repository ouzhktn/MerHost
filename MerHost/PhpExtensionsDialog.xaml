<Window x:Class="MerHost.PhpExtensionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PHP Ayarları" Height="700" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="PHP Ayarları" Foreground="White" FontSize="20" FontWeight="Bold"/>
            <TextBlock x:Name="PhpInfoText" Text="" Foreground="#8B949E" FontSize="13" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Quick Settings -->
        <Border Grid.Row="1" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Hızlı Ayarlar" Foreground="#58A6FF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                <WrapPanel>
                    <Button x:Name="UploadMaxFilesizeBtn" Content="upload_max_filesize: 2M" Click="Setting_Click" Tag="upload_max_filesize" Padding="12,8" Margin="0,0,10,10" Background="#21262D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="PostMaxSizeBtn" Content="post_max_size: 8M" Click="Setting_Click" Tag="post_max_size" Padding="12,8" Margin="0,0,10,10" Background="#21262D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="MaxExecutionTimeBtn" Content="max_execution_time: 30" Click="Setting_Click" Tag="max_execution_time" Padding="12,8" Margin="0,0,10,10" Background="#21262D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="MemoryLimitBtn" Content="memory_limit: 128M" Click="Setting_Click" Tag="memory_limit" Padding="12,8" Margin="0,0,10,10" Background="#21262D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="MaxInputTimeBtn" Content="max_input_time: 60" Click="Setting_Click" Tag="max_input_time" Padding="12,8" Margin="0,0,10,10" Background="#21262D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="DisplayErrorsBtn" Content="display_errors: Off" Click="Setting_Click" Tag="display_errors" Padding="12,8" Margin="0,0,10,10" Background="#21262D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="ErrorReportingBtn" Content="error_reporting: E_ALL" Click="Setting_Click" Tag="error_reporting" Padding="12,8" Margin="0,0,10,10" Background="#21262D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="XdebugBtn" Content="xdebug: Kapalı" Click="Setting_Click" Tag="xdebug" Padding="12,8" Margin="0,0,10,10" Background="#21262D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="🔄 Yenile" Click="Refresh_Click" Padding="15,8" Background="#21262D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="💾 Kaydet ve PHP'yi Yeniden Başlat" Click="SaveAndRestart_Click" Padding="15,8" Margin="15,0,0,0" Background="#238636" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Extensions List -->
        <Border Grid.Row="3" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8">
            <ListView x:Name="ExtensionsList" Background="Transparent" BorderThickness="0" 
                      Foreground="#C9D1D9" FontSize="13">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="" Width="50">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled}" Foreground="#58A6FF"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Eklenti Adı" Width="350">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="#58A6FF"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Durum" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}" Foreground="#8B949E"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Info -->
        <TextBlock Grid.Row="4" Text="Not: Değişiklikler PHP-FPM yeniden başlatıldıktan sonra aktif olur." Foreground="#6E7681" FontSize="12" Margin="0,15,0,0"/>
    </Grid>
</Window>
