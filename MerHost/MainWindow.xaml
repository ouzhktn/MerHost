<Window x:Class="MerHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="MerHost - Localhost Server" Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        Background="#0D1117">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="Button" x:Key="StopButton">
            <Setter Property="Background" Value="#DA3633"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button" x:Key="IconButton">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style TargetType="Button" x:Key="QuickLinkButton">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#58A6FF"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionTitle">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#161B22" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="⚡" FontSize="28" VerticalAlignment="Center"/>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="MerHost" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Localhost Server" FontSize="11" Foreground="#8B949E"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="📂" ToolTip="www Klasörünü Aç" Click="OpenWwwFolder_Click" Style="{StaticResource IconButton}" Padding="12"/>
                    <Button Content="⚙️" ToolTip="Ayarlar" Click="Settings_Click" Style="{StaticResource IconButton}" Margin="8,0,0,0"/>
                    <Button Content="🔌" ToolTip="PHP Eklentileri" Click="PhpExtensions_Click" Style="{StaticResource IconButton}" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="1" Background="#0D1117" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="#DA3633"/>
                    <TextBlock x:Name="StatusText" Text="Durduruldu" Foreground="#F85149" FontSize="16" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="UrlText" Text="" Foreground="#58A6FF" FontSize="14" Margin="20,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="StartButton" Content="▶ Sunucuyu Başlat" Style="{StaticResource PrimaryButton}" Click="StartButton_Click"/>
                    <Button x:Name="StopButton" Content="■ Sunucuyu Durdur" Style="{StaticResource StopButton}" Click="StopButton_Click" Margin="10,0,0,0" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Services -->
                <StackPanel Grid.Row="0" Margin="0,0,0,0">
                    <TextBlock Text="SERVİSLER" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Nginx -->
                        <Border Grid.Column="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Nginx" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="NginxStatus" Text="●" Foreground="#6E7681" FontSize="14" HorizontalAlignment="Right"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="▶" Click="StartNginx_Click" Padding="12,6" Background="#238636" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="■" Click="StopNginx_Click" Padding="12,6" Margin="8,0,0,0" Background="#DA3633" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- PHP -->
                        <Border Grid.Column="1" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5,0">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="PHP-FPM" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="PhpStatus" Text="●" Foreground="#6E7681" FontSize="14" HorizontalAlignment="Right"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="▶" Click="StartPhp_Click" Padding="12,6" Background="#238636" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="■" Click="StopPhp_Click" Padding="12,6" Margin="8,0,0,0" Background="#DA3633" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- MySQL -->
                        <Border Grid.Column="2" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="15" Margin="5,0">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="MySQL" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="MysqlStatus" Text="●" Foreground="#6E7681" FontSize="14" HorizontalAlignment="Right"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="▶" Click="StartMysql_Click" Padding="12,6" Background="#238636" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="■" Click="StopMysql_Click" Padding="12,6" Margin="8,0,0,0" Background="#DA3633" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Node.js -->
                        <Border Grid.Column="3" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Node.js" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="NodeStatus" Text="●" Foreground="#6E7681" FontSize="14" HorizontalAlignment="Right"/>
                                </Grid>
                                <TextBlock x:Name="NodePortText" Text="Port: 3000" Foreground="#8B949E" FontSize="11" Margin="0,5,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="▶" Click="StartNode_Click" Padding="12,6" Background="#238636" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="■" Click="StopNode_Click" Padding="12,6" Margin="8,0,0,0" Background="#DA3633" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Node.js Development -->
                    <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="NODE.JS GELİŞTİRME" Foreground="#8B949E" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock x:Name="NodeProjectPath" Text="Proje seçilmedi" Foreground="#58A6FF" FontSize="11" HorizontalAlignment="Right"/>
                            </Grid>
                            
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <Button Content="📂 Proje Seç" Click="SelectNodeProject_Click" Padding="15,8" Background="#1F6FEB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <Button Content="📦 npm install" Click="NpmInstall_Click" Padding="15,8" Margin="10,0,0,0" Background="#238636" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <Button Content="▶ npm start" Click="NpmStart_Click" Padding="15,8" Margin="10,0,0,0" Background="#238636" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <Button Content="🔗 Tarayıcıda Aç" Click="OpenNodeInBrowser_Click" Padding="15,8" Margin="10,0,0,0" Background="#1F6FEB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <Button Content="■ Durdur" Click="NpmStop_Click" Padding="15,8" Margin="10,0,0,0" Background="#DA3633" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Domains & Logs -->
                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Domains -->
                    <Border Grid.Column="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="DOMAINLER" Foreground="#8B949E" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Content="+ Yeni Domain" Click="CreateDomain_Click" HorizontalAlignment="Right" Padding="12,6" Background="#1F6FEB" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="12"/>
                            </Grid>

                            <ListBox x:Name="DomainList" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                                     Foreground="#58A6FF" FontFamily="Consolas" FontSize="13" 
                                     MouseDoubleClick="DomainList_MouseDoubleClick"/>
                        </Grid>
                    </Border>

                    <!-- Logs -->
                    <Border Grid.Column="1" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="LOG" Foreground="#8B949E" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Content="📋 Kopyala" Click="CopyLog_Click" HorizontalAlignment="Right" Padding="8,4" Background="#21262D" Foreground="#8B949E" BorderThickness="0" Cursor="Hand" FontSize="11"/>
                            </Grid>

                            <ListBox x:Name="LogList" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                                     Foreground="#C9D1D9" FontFamily="Consolas" FontSize="11" 
                                     SelectionMode="Extended"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#161B22" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="WwwPathText" Text="www: " Foreground="#6E7681" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PhpVersionText" Text="" Foreground="#6E7681" FontSize="11" VerticalAlignment="Center" Margin="20,0,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="v1.0.0" Foreground="#484F58" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- System Tray -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="MerHost"
                        Visibility="Visible">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Göster" Click="ShowMenuItem_Click"/>
                    <MenuItem Header="Başlat" Click="StartMenuItem_Click"/>
                    <MenuItem Header="Durdur" Click="StopMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="Çıkış" Click="ExitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
